```python
import numpy as np
import pandas as pd

def convert_to_dataframe(data):
    df = pd.DataFrame(data, columns=['start_time', 'day_of_week', 'duration', 'place_id'])
    return df

def predict_next_location(history, context):
    try:
        # Convert history and context into DataFrames
        df_history = convert_to_dataframe(history)
        df_context = convert_to_dataframe(context)

        # Group history by place ID and calculate the frequency of visits to each place
        place_visits_frequency = defaultdict(int)
        for index, row in df_history.iterrows():
            place_visits_frequency[row['place_id']] += 1

        # Calculate visit probability for each place
        place_visit_probabilities = {}
        total_places_visited = len(place_visits_frequency.keys())

        for place_id, frequency in place_visits_frequency.items():
            place_visit_probabilities[place_id] = frequency / total_places_visited

        # Get the context and recent activities of this user
        df_context_recent_activities = df_context.sort_values(by='start_time')

        # Predict next location based on historical stay pattern and contextual information 
        predicted_next_location_place_ids = {}

        # 1. Repeated visits to certain places during certain times
        for place_id, probability in place_visit_probabilities.items():
            recent_activity_count = df_context_recent_activities[df_context_recent_activities['place_id'] == place_id].shape[0]
            if (recent_activity_count > 0) & ((probability / recent_activity_count) >= 0.3):
                predicted_next_location_place_ids[place_id] = probability / recent_activity_count

        # 2. Recent activities
        for index, row in df_context_recent_activities.iterrows():
            place_id = row['place_id']
            if place_id not in predicted_next_location_place_ids:
                predicted_next_location_place_ids[place_id] = (1 + np.log(row['duration'])) / 5

        # Rank the places by their probabilities
        ranked_places_by_probability = sorted(predicted_next_location_place_ids.items(), key=lambda x: x[1], reverse=True)

        # Return top-10 most probable locations as output
        prediction = [x[0] for x in ranked_places_by_probability[:10]]
        
        return {
            'prediction': prediction,
            'reason': "Based on the analysis of historical stay pattern and recent contextual activities, the 10 most likely places are: {}".format(prediction)
        }

    except Exception as e:
        print("Error occurred during execution:", str(e))
        return None

# Example usage
