import numpy as np

def get_hour(date_str):
    """Extracts the hour from a date string."""
    date_parts = date_str.split()
    return int(date_parts[0].split(':')[0])

def build_markov_history(stay_history, recent_stays):
    """
    Combines historical stays with recent context (excluding the last stay 
    from history which is already included in context) and groups them by 
    place_id and day_of_week to simulate Markov chain transitions.
    """
    combined_stays = stay_history + recent_stays[:-1]

    markov_transitions = {}
    for i in range(len(combined_stays) - 1):
        hour_now = get_hour(combined_stays[i][0])
        hour_next = get_hour(combined_stays[i + 1][0])

        place_id = combined_stays[i][3]
        next_place_id = combined_stays[i + 1][3]

        day_of_week = combined_stays[i][1]
        if (place_id, day_of_week) not in markov_transitions:
            markov_transitions[(place_id, day_of_week)] = {}

        transition_key = (hour_now % 24, hour_next % 24)
        if transition_key not in markov_transitions[(place_id, day_of_week)]:
            markov_transitions[(place_id, day_of_week)][transition_key] = {}

        next_place_id_count = markov_transitions[(place_id, day_of_week)][transition_key].get(next_place_id, 0)
        markov_transitions[(place_id, day_of_week)][transition_key][next_place_id] = next_place_id_count + 1

    return markov_transitions

def get_next_transition_probabilities(transitions, current_state, hour_now, hour_next):
    """
    Determines the transition key based on hour and gets corresponding 
    probabilities.
    """
    next_transition_key = (hour_now % 24, hour_next % 24)
    next_place_id_probabilities = transitions[current_state].get(next_transition_key)

    if next_place_id_probabilities:
        # Normalize to ensure probabilities add up to 1
        total_places_from_transition = sum(next_place_id_probabilities.values())
        if total_places_from_transition > 0:
            normalized_probabilities = {
                place_id: prob / total_places_from_transition for place_id, prob in next_place_id_probabilities.items()
            }

        return normalized_probabilities

    return None

def predict_next_location(stay_history, recent_stays):
    """
    Predicts the user's next location based on their historical stays and 
    recent context using a Markov chain model.
    """
    # Get the last stay as it's relevant for immediate prediction
    last_recent_stay = recent_stays[-1]

    # Build Markov chain model based on history and recent stays
    markov_transitions = build_markov_history(stay_history, recent_stays)

    current_state = (last_recent_stay[3], last_recent_stay[1])
    hour_now = get_hour(last_recent_stay[0])
    hour_next = 12  # Assuming it's part of the context

    next_place_id_probabilities = get_next_transition_probabilities(markov_transitions, current_state, hour_now, hour_next)

    if next_place_id_probabilities:
        # Return top 10 predicted places
        return sorted(next_place_id_probabilities.items(), key=lambda x: x[1], reverse=True)[:10]

    return None

stay_history = [
    ('08:00 AM', 'Monday', 123, np.int64(19)),
    ('09:30 PM', 'Tuesday', 456, np.int64(17))
]
recent_stays = [('03:45 PM', 'Wednesday', 123, np.int64(19)), ('04:35 PM', 'Wednesday', 542, np.int64(12))]

predicted_places = predict_next_location(stay_history, recent_stays)
print(predicted_places)
```

