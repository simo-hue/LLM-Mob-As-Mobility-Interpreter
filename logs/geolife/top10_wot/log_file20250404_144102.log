import numpy as np

def count_historical_place_visits(history, num_places):
    """
    Count occurrences of each place ID in historical stays.
    
    Args:
        history (list): A list containing this user's historical stays, each as (start_time, day_of_week, duration, place_id).
        num_places (int): The number of places to return.
        
    Returns:
        dict: A dictionary with place IDs as keys and their occurrence counts as values, sorted in descending order.
    """
    
    # Count occurrences of each place ID
    place_id_counts = defaultdict(int)
    for stay in history:
        place_id_counts[stay[3]] += 1
    
    # Sort places by their occurrence count and select top-N most visited places
    ranked_places = sorted(place_id_counts.items(), key=lambda x: x[1], reverse=True)[:num_places]
    
    return dict(ranked_places)


def predict_next_place(history, context, num_places):
    """
    Predict next places based on contextual information.
    
    Args:
        history (list): A list containing this user's historical stays, each as (start_time, day_of_week, duration, place_id).
        context (list): A list of recent visits, each as (visit_time, visit_duration, place_id).
        num_places (int): The number of places to return.
        
    Returns:
        dict: A dictionary with predicted next places and their probabilities.
    """
    
    # Count historical place visits
    ranked_places = count_historical_place_visits(history, num_places)
    
    # Calculate contextual probability weights for each place
    context_weights = {}
    for visit in context:
        place_id = visit[2]
        context_weights[place_id] = 1 / (visit[1] + 1)  # Simplified weight calculation
    
    # Normalize probabilities by multiplying with contextual weights and summing across all places
    total_weight = sum(context_weights.values())
    normalized_weights = {k: v / total_weight for k, v in context_weights.items()}
    
    # Predict next places based on historical occurrence counts and contextual weights
    predicted_places = {}
    for place_id, weight in normalized_weights.items():
        if place_id in ranked_places:
            predicted_places[place_id] = (ranked_places[place_id] * weight) / sum(ranked_places.values())
    
    return predicted_places


def main(history, context):
    num_places = 5
    predicted_result = predict_next_place(history, context, num_places)
    print(predicted_result)


if __name__ == "__main__":
    history = [
        # Example historical visits...
    ]
    context = [
        # Example recent visits...
    ]
    
    main(history, context)

```

