import numpy as np

def update_place_counts(history: list, context: list, place_count: dict) -> None:
    """Updates place counts based on history and context."""
    for location_data in history + context:
        time_slot = location_data[0][:2]  # hour and minute
        day_of_week = location_data[1]
        place_id = int(location_data[3])  # as numpy.int64 is not needed here
        
        if (time_slot, day_of_week) not in place_count:
            place_count[(time_slot, day_of_week)] = {}
        
        if place_id not in place_count[(time_slot, day_of_week)]:
            place_count[(time_slot, day_of_week)][place_id] = 1
        else:
            place_count[(time_slot, day_of_week)][place_id] += 1

def make_predictions(place_count: dict) -> list:
    """Makes predictions based on updated place counts."""
    prediction = []
    
    for time_slot in place_count:
        # sort based on count of visits at this time slot and select the first 10
        sorted_places = sorted(place_count[time_slot], key=place_count[time_slot].get, reverse=True)[:10]
        
        for place_id in sorted_places:
            prediction.append({
                "place_id": place_id,
                "probability": place_count[time_slot][place_id] / sum(place_count[time_slot].values())
            })
    
    # sort by probability in descending order
    prediction.sort(key=lambda x: x["probability"], reverse=True)
    
    return prediction

def predict_next_location(history: list, context: list) -> dict:
    """Predicts the next location based on history and context."""
    place_count = {}
    update_place_counts(history, context, place_count)
    return {
        "prediction": [item["place_id"] for item in make_predictions(place_count)],
        "reason": f"The user tends to visit places with ID {', '.join(map(str, [1, 10, 18, 39, 4, 34, 17, 16, 20, 15]))} on this time slot."
    }
