import numpy as np
from collections import defaultdict

# Given data
history = [('05:22 AM', 'Thursday', 73, np.int64(10)), 
           ('06:41 AM', 'Thursday', 198, np.int64(17)),
           # ... (rest of the history data)
          ]

context = [('09:08 PM', 'Wednesday', 466, np.int64(10)), 
           ('04:58 AM', 'Thursday', 187, np.int64(17)),
           # ... (rest of the context data)
          ]

def calculate_transition_probabilities(history):
    """Calculate transition probabilities for each place ID."""
    transition_probabilities = defaultdict(dict)

    for i in range(len(history)):
        hour_of_day = int(history[i][0][:2])
        
        if history[i-1] is not None:
            previous_place_id = history[i-1][-1]
            
            if previous_place_id not in transition_probabilities:
                transition_probabilities[previous_place_id] = {}
                
            current_place_id = history[i][-1]
            
            if current_place_id not in transition_probabilities[previous_place_id]:
                transition_probabilities[previous_place_id][current_place_id] = 0
                
            # Increment the count for the next place ID
            transition_probabilities[previous_place_id][current_place_id] += 1
            
    return transition_probabilities

def calculate_next_place_id_probabilities(transition_probabilities, context):
    """Calculate the probabilities of each possible next place ID."""
    probabilities = {}
    
    for previous_place_id in transition_probabilities:
        total_transitions = sum(transition_probabilities[previous_place_id].values())
        
        if previous_place_id not in context:
            for current_place_id in transition_probabilities[previous_place_id]:
                # Calculate the probability of transitioning to this place ID
                probabilities[(previous_place_id, current_place_id)] = transition_probabilities[previous_place_id][current_place_id] / total_transitions
                
    return probabilities

def calculate_next_place_id_probabilities_context(history, context):
    """Calculate the next place ID based on the context and history."""
    # Calculate the place IDs in the context
    context_place_ids = [stay[-1] for stay in context]
    
    probability_context = 0.2
    probability_history = 0.8

    next_place_id_probabilities = {}
    
    transition_probabilities = calculate_transition_probabilities(history)
    
    for previous_place_id in transition_probabilities:
        # Consider only the previous place IDs that are also in the context
        if previous_place_id in context_place_ids:
            for current_place_id in probabilities[(previous_place_id, 'all')]:
                next_place_id_probabilities[current_place_id] = (probability_history * 
                                                                   probabilities[(previous_place_id, current_place_id)] +
                                                                   probability_context / len(context))

    return next_place_id_probabilities

# Calculate the transition probabilities
