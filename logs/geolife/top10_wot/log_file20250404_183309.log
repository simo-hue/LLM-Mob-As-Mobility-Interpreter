import numpy as np
from collections import Counter, defaultdict

def predict_next_location(user_history: list, current_context: list) -> str:
    """
    Predicts the next location based on a user's activity pattern.
    
    Args:
        user_history (list): A list of tuples containing the start time, day of week, duration, and place ID for each stay in the history.
        current_context (list): A list of tuples containing the start time, day of week, duration, and place ID for each stay in the current context.
    
    Returns:
        str: A JSON string containing the prediction and reason.
    """

    # Create a dictionary to store the frequency of each place
    place_freq = Counter()
    
    # Iterate over each stay in the history
    for start_time, day_of_week, duration, place_id in user_history:
        # Increment the frequency of the current place
        place_freq[place_id] += 1
    
    # Create a dictionary to store the recent context stays
    recent_stays = Counter()
    
    # Iterate over each stay in the current context
    for start_time, day_of_week, duration, place_id in current_context:
        # If the place is already in the recent stays dictionary, increment its count
        if place_id in recent_stays:
            recent_stays[place_id] += 1
        # Otherwise, add it to the dictionary with a count of 1
        else:
            recent_stays[place_id] = 1
    
    # Create a list to store the predicted places and their probabilities
    predicted_places = []
    
    # Iterate over each place in the frequency dictionary
    for place_id in place_freq:
        # Calculate the probability of the current place based on its frequency and recent stays
        probability = (place_freq[place_id] + recent_stays.get(place_id, 0)) / (len(user_history) + len(current_context))
        
        # Add the predicted place and its probability to the list
        predicted_places.append((place_id, probability))
    
    # Sort the predicted places in descending order of their probabilities
    predicted_places.sort(key=lambda x: x[1], reverse=True)
    
    # Select the top 10 predicted places
    top_predicted_places = predicted_places[:10]
    
    # Create a JSON object with the prediction and reason
    prediction = {
        "prediction": [place_id for place_id, _ in top_predicted_places],
        "reason": f"The model predicts the next location based on the user's activity pattern, which includes repeated visits to certain places during certain times. The recent context stays also indicate that the user is likely to visit these places again."
    }
    
