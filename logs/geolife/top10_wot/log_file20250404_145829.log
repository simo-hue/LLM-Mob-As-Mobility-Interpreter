    # Define feature extraction function (in this case, we'll use categorical features only)
    def extract(row):
        start_time = row['start_time']
        day_of_week = row['day_of_week']
        duration = row['duration']

        # Extract categorical features
        features = {
            'start_time': pd.get_dummies(start_time)[0],
            'day_of_week': pd.get_dummies(day_of_week).sum()
        }

        return features

    # Apply feature extraction function to each row in the DataFrame
    df_extracted_features = df.apply(extract, axis=1)

    return df_extracted_features

