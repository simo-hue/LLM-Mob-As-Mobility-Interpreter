import pandas as pd
from collections import defaultdict
import numpy as np

def count_place_visits(stays):
    """
    Counts the number of times each place has been visited.

    Args:
        stays (list): List of tuples containing stay information, including time, day, duration, and place ID.

    Returns:
        dict: Dictionary mapping place IDs to their respective visit counts.
    """
    place_counts = defaultdict(int)
    for stay in stays:
        _, _, _, place_id = stay
        place_counts[place_id] += 1
    return dict(place_counts)

def predict_next_location(history, context):
    """
    Predicts the top 10 places a user is likely to visit next based on their historical and contextual data.

    Args:
        history (list): List of tuples containing historical stay information.
        context (list): List of tuples containing contextual stay information.

    Returns:
        dict: Dictionary containing the predicted place IDs and a reason for the prediction.
    """
    # Combine historical and contextual data
    combined_data = history + context

    # Count the number of times each place has been visited in both history and context
    place_counts_history = count_place_visits(history)
    place_counts_context = count_place_visits(context)

    # Calculate total visits to each place, considering both history and context
    total_place_counts = {**place_counts_history, **place_counts_context}

    # Get the most recent stay from the context (if any)
    recent_stay_context = context[-1] if context else None

    # Get the next location based on the recent stay in the context
    if recent_stay_context:
        _, _, duration, place_id = recent_stay_context
        if place_id not in total_place_counts or history[-1][3] == place_id:
            # If this is a unique visit (never seen before), assign it as 1/total_visits
            total_places = len(total_place_counts)
            next_place_prob = 1 / total_places
        else:
            # Otherwise, calculate the probability based on frequency of visits to this place in history and context
            total_visits_to_place_in_history = place_counts_history.get(place_id, 0)
            total_visits_to_place_in_context = place_counts_context.get(place_id, 0)
            next_place_prob = (total_visits_to_place_in_history + total_visits_to_place_in_context) / len(combined_data)
    else:
        # If there is no recent stay in the context, assign equal probability to all places
        total_places = len(total_place_counts)
        if not history or history[-1][3] not in place_counts_history and history[-1][3] not in place_counts_context:
            next_place_prob = 1 / total_places
        else:
            # Otherwise, calculate the probability based on frequency of visits to this place in history and context
            _, _, duration, last_place_id = history[-1]
            total_visits_to_last_place_in_history = place_counts_history.get(last_place_id, 0)
            total_visits_to_last_place_in_context = place_counts_context.get(last_place_id, 0)
            next_place_prob = (total_visits_to_last_place_in_history + total_visits_to_last_place_in_context) / len(combined_data)

    # Predict the top 10 places
    predicted_places = sorted(total_place_counts.items(), key=lambda item: item[1], reverse=True)[:10]

    return {
        "prediction": [place_id for place_id, _ in predicted_places],
        "reason": f"Based on historical and contextual data, the user is most likely to visit these places next. The predictions are based on the frequency of visits to each place in both history and context."
    }

