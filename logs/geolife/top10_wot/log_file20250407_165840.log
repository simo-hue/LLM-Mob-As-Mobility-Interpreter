def build_frequency_mapping(data):
    """Builds a mapping from (day_of_week, place_id) to frequency and total duration."""
    mapping = defaultdict(lambda: [0, 0])
    for item in data:
        day, place_id = item[1], int(item[3])
        mapping[(day, place_id)][0] += 1
        mapping[(day, place_id)][1] += item[2]
