import pandas as pd
from collections import defaultdict

# Given data
history = [...]  # Your history data here
context = [...]  # Your context data here

def load_data(history, context):
    """Load the given data into DataFrames"""
    history_df = pd.DataFrame(history, columns=['start_time', 'day_of_week', 'duration', 'place_id'])
    context_df = pd.DataFrame(context, columns=['start_time', 'day_of_week', 'duration', 'place_id'])

    # Merge the two DataFrames
    merged_df = pd.concat([history_df, context_df])

    return merged_df

def process_data(merged_df):
    """Process the data by converting start_time to datetime format and extracting hour of day"""
    merged_df['start_time'] = pd.to_datetime(merged_df['start_time'], format='%I:%M %p')
    merged_df['hour_of_day'] = merged_df['start_time'].dt.hour

    return merged_df

def calculate_place_frequencies(merged_df):
    """Calculate place_id frequencies"""
    place_freq = defaultdict(int)

    for _, row in merged_df.iterrows():
        place_freq[row['place_id']] += 1

    return place_freq

def calculate_probabilities(place_freq, merged_df):
    """Calculate probabilities for each place_id"""
    probabilities = {k: v / len(merged_df) for k, v in place_freq.items()}

    return probabilities

def get_top_places(probabilities):
    """Get the top 10 most probable places"""
    sorted_places = sorted(probabilities, key=probabilities.get, reverse=True)
    top_10_places = sorted_places[:10]

    return top_10_places

# Main logic
merged_df = load_data(history, context)
processed_df = process_data(merged_df)
place_freq = calculate_place_frequencies(processed_df)
probabilities = calculate_probabilities(place_freq, processed_df)
top_10_places = get_top_places(probabilities)

prediction = {
    "prediction": top_10_places,
    "reason": "The prediction is based on the user's activity pattern and recent activities."
}

print(prediction)
