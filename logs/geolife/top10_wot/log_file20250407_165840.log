import pandas as pd
import numpy as np

def load_data(history_path):
    # Load history data from file
    try:
        history_df = pd.read_csv(history_path)
    except Exception as e:
        print(f"Error loading history data: {e}")
        return None
    
    # Load context data from file
    context_df = pd.read_csv(context_path)
    
    return pd.concat([history_df, context_df])

def preprocess_data(df):
    # Handle missing or invalid values
    df.dropna(inplace=True)
    
    # Convert place_id to categorical type
    df['place_id'] = pd.Categorical(df['place_id'])
    
    return df

def train_model(df):
    # Infer the next location based on the activity pattern and context
    place_freq = {}
    for index, row in df.iterrows():
        if row['place_id'] not in place_freq:
            place_freq[row['place_id']] = 0
        place_freq[row['place_id']] += 1
    
    # Get the top 10 most frequent places
    top_places = sorted(place_freq.items(), key=lambda x: x[1], reverse=True)[:10]
    
    return top_places

def make_prediction(top_places):
    next_location_infered = None
    for (place_id, freq) in top_places:
        # Calculate the probability of each place being the next location
        prob = freq / len(place_freq)
        
        if next_location_infered is None or prob > next_location_infered[1]:
            next_location_infered = (place_id, prob)
    
    return next_location_infered

def output_result(next_location_infered):
    result = {
        'prediction': [x[0] for x in top_places],
        'reason': f"The user's activity pattern and context suggest that they are likely to visit places with IDs {', '.join([str(x) for x in next_location_infered[0]])} with probabilities of {next_location_infered[1]:.2f}, because these places have been visited frequently in the past."
    }
    
    return result

# Main function
if __name__ == "__main__":
    history_path = "history.csv"
    context_path = "context.csv"
    
    df = load_data(history_path)
    if df is not None:
        df = preprocess_data(df)
        top_places = train_model(df)
        next_location_infered = make_prediction(top_places)
        result = output_result(next_location_infered)
        
        print(result)
```

