import numpy as np
from collections import defaultdict
import json

def calculate_transition_probabilities(history):
    """Calculate transition probabilities from historical data."""
    
    transitions = defaultdict(lambda: defaultdict(int))
    
    for i in range(len(history) - 1):
        start_time, day_of_week, duration, place_id = history[i]
        next_start_time, next_day_of_week, next_duration, next_place_id = history[i + 1]
        
        transitions[(day_of_week, place_id)][(next_day_of_week, next_place_id)] += 1

    for (prev_dw, prev_pl), transition_count in transitions.items():
        total_transitions = sum(transition_count.values())
        for (dw, pl) in transition_count:
            transitions[(prev_dw, prev_pl)][(dw, pl)] /= total_transitions
            
    return transitions


def calculate_context_transition_probabilities(context):
    """Calculate transition probabilities from context data."""
    
    context_transitions = defaultdict(lambda: defaultdict(int))
    
    for i in range(len(context)):
        start_time, day_of_week, duration, place_id = context[i]
        
        context_transitions[(day_of_week, place_id)][(next_day_of_week, next_place_id)] += 1

    for (prev_dw, prev_pl), transition_count in context_transitions.items():
        total_transitions = sum(transition_count.values())
        for (dw, pl) in transition_count:
            context_transitions[(prev_dw, prev_pl)][(dw, pl)] /= total_transitions
            
    return context_transitions


def combine_transition_probabilities(transitions, context_transitions):
    """Combine the two sources of transitions and calculate final probabilities."""
    
    combined_transitions = defaultdict(lambda: defaultdict(int))
    
    for transition in transitions.items():
        dw, pl = transition[0]
        for next_transition in transition[1].items():
            dw2, pl2 = next_transition[0]
            combined_transitions[(dw, pl)][(dw2, pl2)] += context_transitions[(dw, pl)].get((dw2, pl2), 0) * transition[1][next_transition[0]] / sum(context_transitions[(dw, pl)].values())
        
    return combined_transitions


def predict_next_location(history, context):
    """Predict the user's next location based on their historical stays and recent activities."""
    
    transitions = calculate_transition_probabilities(history)
    context_transitions = calculate_context_transition_probabilities(context)
    combined_transitions = combine_transition_probabilities(transitions, context_transitions)

    prediction = []
    
    for (dw, pl), transitions in combined_transitions.items():
        max_transition = max(transitions.values())
        places = [(dw, pl2) for (dw2, pl2), transition_prob in transitions.items() if transition_prob == max_transition]
        
        # If there are multiple possible locations with the same maximum probability,
        # choose one of them randomly
        prediction.append((dw, pl, next(places)))

    return prediction


def generate_prediction(prediction):
    """Generate a single predicted location from the list of possible locations."""
    
    return (prediction[0][0], prediction[0][1])


# Example usage:
history = [('07:00 AM', 'Monday', 30, np.int64(12)), ('09:00 AM', 'Tuesday', 15, np.int64(13))]
context = [('08:00 AM', 'Wednesday', 20, np.int64(14))]

print(predict_next_location(history, context))
