import numpy as np
from collections import defaultdict
import json
import random

def predict_next_place(history, context):
    # Learn the transition probabilities from history
    transitions = defaultdict(dict)
    for i in range(len(history) - 1):
        place_id = history[i][3]
        next_place_id = history[i + 1][3]
        if place_id not in transitions:
            transitions[place_id] = {}
        if next_place_id not in transitions[place_id]:
            transitions[place_id][next_place_id] = 0
        transitions[place_id][next_place_id] += 1

    # Update the transition probabilities with recent context stays
    for stay in context:
        place_id = stay[3]
        if place_id not in transitions:
            continue
        next_transitions = {}
        for next_place_id, count in transitions[place_id].items():
            decay_factor = 0.9
            next_transitions[next_place_id] = (count + 1) * decay_factor / (len(history) - i)
        transitions[place_id] = next_transitions

    # Predict the top 10 most likely places to visit next
    total_places = len(transitions)
    prediction_probabilities = {}
    for place_id, next_transitions in transitions.items():
        probability = sum(next_transitions.values()) / (total_places * len(history))
        prediction_probabilities[place_id] = probability

    sorted_ids = sorted(prediction_probabilities.keys(), key=lambda x: -prediction_probabilities[x])[:10]
    next_place_ids = [{"id": id, "probability": prediction_probabilities[id]} for id in sorted_ids]

    # Convert the probabilities to JSON string
    json_str = json.dumps(next_place_ids)

    prediction = {
        "next_place_id": json_str,
        "reason": f"The next place to visit is likely {sorted_ids[0]}."
    }
    return prediction

